-            ret = v4l2_bufref_to_buf(out, 0, frame->data[i], size, offset);
-            if (ret)
-                return ret;
-            offset += size;
+            if (bytesperline == frame->linesize[0]) {
+                size = frame->linesize[i] * h;
+                ret = v4l2_bufref_to_buf(out, 0, frame->data[i], size, offset);
+                if (ret)
+                    return ret;
+                offset += frame->linesize[i] * (i ? scanline_uv : scanline_y);
